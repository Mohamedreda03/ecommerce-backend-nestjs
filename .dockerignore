# Dependencies — never copy node_modules into the image
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output — we compile inside the container
dist
build

# Test artefacts
coverage
.nyc_output
**/*.spec.ts
**/*.e2e-spec.ts
test/

# Development environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Docker files themselves (no recursion)
docker-compose*.yml
Dockerfile*
.dockerignore

# Git
.git
.gitignore
.gitattributes

# IDE / editor
.vscode
.idea
*.sublime-workspace
*.sublime-project

# OS junk
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Temporary files
.temp
.tmp
tmp/

# Prisma migrations are included (needed for `prisma migrate deploy`)
# prisma/migrations — DO NOT IGNORE

# Uploads directory — runtime data, not source code
uploads/
