# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# PostgreSQL (matches docker-compose.yml defaults)
# Dev  (app on host, DB in Docker): use localhost
# Prod (app in Docker):             use the service name "postgres"
# -----------------------------------------------------------------------------
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_password
POSTGRES_DB=ecommerce
POSTGRES_PORT=5434

# Main database URL
DATABASE_URL=postgresql://ecommerce:ecommerce_password@localhost:5432/ecommerce?schema=public

# -----------------------------------------------------------------------------
# Redis (matches docker-compose.yml defaults)
# Dev  (app on host): REDIS_HOST=localhost
# Prod (app in Docker): REDIS_HOST=redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
# Full Redis URL — used by ioredis and bull
REDIS_URL=redis://:redis_password@localhost:6379

# -----------------------------------------------------------------------------
# JWT — use strong random secrets in production (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev_access_secret_do_not_use_in_production_replace_with_64_char_random_string
JWT_REFRESH_SECRET=dev_refresh_secret_do_not_use_in_production_replace_with_64_char_random_string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Stripe Payments
# Get keys from https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# Mail Configuration
# Use real SMTP details here (Gmail, SendGrid, Mailgun, AWS SES, etc.)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@ecommerce.com
MAIL_FROM_NAME=Ecommerce Store

# -----------------------------------------------------------------------------
# File Uploads
# Relative path for local disk storage (created automatically)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# -----------------------------------------------------------------------------
# Frontend (used for CORS and password-reset redirect URLs)
# -----------------------------------------------------------------------------
# You can provide a single URL or a comma-separated list, e.g.:
# FRONTEND_URL=http://localhost:3001,http://localhost:5173
FRONTEND_URL=http://localhost:3001,http://localhost:5173

# -----------------------------------------------------------------------------
# Shipping (simple flat-rate calculation)
# -----------------------------------------------------------------------------
FREE_SHIPPING_THRESHOLD=100
FLAT_SHIPPING_RATE=10
